# Copy to .env (gitignored) for local dev, or set these in Vercel →
# Project → Settings → Environment Variables, then redeploy.

# Canonical site URL (no trailing slash). Defaults to the Vercel domain.
# NEXT_PUBLIC_SITE_URL=https://open-icons.vercel.app

# Search Console / Webmaster ownership verification tokens.
# Google: Search Console → Add property (URL prefix) → HTML tag → copy the
#         content="..." value (just the token, not the whole tag).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing: Webmaster Tools → Add site → Meta tag → copy the content="..." value.
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
