# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*

# next.js
/.next/
/out/
/build
next-env.d.ts

# production
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# generated icon manifests + search index (auto-synced at build time, never committed)
/src/data/
/public/data/*
# fingerprints are expensive to regenerate (fetches ~18k SVGs) and are NOT part
# of prebuild, so commit this one so the deployed plugin can fetch it.
!/public/data/fingerprints.json
/.icon-cache/

# secrets
secrets.local
*.local

# community video build (regenerable; node_modules is huge)
/figma-plugin/community/_video/node_modules/
/figma-plugin/community/_video/*.wav
/figma-plugin/community/_video/frame_*.png
/figma-plugin/community/_src/*.html
